generator client {
    provider = "prisma-client"
    output   = "./__generated__"
}

datasource db {
    provider = "postgresql"
}

model User {
    id                String             @id @default(cuid())
    email             String             @unique
    phone             String?            @unique
    password          String?
    username          String?            @unique
    firstName         String?            @map("first_name")
    lastName          String?            @map("last_name")
    description       String?
    avatar            String?            @default("/uploads/no-user-image.png")
    isPasswordEnabled Boolean            @default(false) @map("is_password_enabled")
    status            EnumUserStatus     @default(OFFLINE)
    role              EnumUserRole       @default(USER)
    visibility        EnumUserVisibility @default(VISIBLE)
    lastSeen          DateTime           @updatedAt @map("last_seen")
    createdAt         DateTime           @default(now()) @map("created_at")
    updatedAt         DateTime           @updatedAt @map("updated_at")
    deletedAt         DateTime?          @map("deleted_at")

    messages      Message[]
    createdChats  Chat[]
    chats         ChatMember[]
    archivedChats ArchivedChat[]
    mutedChats    MutedChat[]
    pinnedChats   PinnedChat[]
    chatAdmins    ChatAdmin[]
    messageStatus MessageStatus[]
    friendships   Friendship[]    @relation("UserFriends")
    friendOf      Friendship[]    @relation("FriendOf")

    @@index([email])
    @@index([username])
    @@index([phone])
    @@map("users")
}

model Friendship {
    id        String               @id @default(cuid())
    status    EnumFriendshipStatus @default(PENDING)
    createdAt DateTime             @default(now()) @map("created_at")
    updatedAt DateTime             @updatedAt @map("updated_at")

    user     User   @relation("UserFriends", fields: [userId], references: [id], onDelete: Cascade)
    userId   String @map("user_id")
    friend   User   @relation("FriendOf", fields: [friendId], references: [id], onDelete: Cascade)
    friendId String @map("friend_id")

    @@unique([userId, friendId])
    @@index([userId])
    @@index([friendId])
    @@index([status])
    @@map("friendships")
}

model Chat {
    id              String       @id @default(cuid())
    name            String?
    description     String?
    avatar          String?      @default("/uploads/no-chat-image.png")
    pinnedMessageId String?      @map("pinned_message_id")
    lastMessageId   String?      @map("last_message_id")
    isPrivate       Boolean      @default(false) @map("is_private")
    type            EnumChatType @default(DIRECT)
    createdAt       DateTime     @default(now()) @map("created_at")
    updatedAt       DateTime     @updatedAt @map("updated_at")
    deletedAt       DateTime?    @map("deleted_at")

    inviteLink   InviteLink?
    inviteLinkId String?        @unique @map("invite_link_id")
    createdBy    User           @relation(fields: [createdById], references: [id])
    createdById  String         @map("created_by_id")
    members      ChatMember[]
    admins       ChatAdmin[]
    archivedBy   ArchivedChat[]
    mutedBy      MutedChat[]
    pinnedChats  PinnedChat[]
    messages     Message[]

    @@unique([id, inviteLinkId])
    @@index([deletedAt])
    @@index([updatedAt])
    @@index([createdAt])
    @@index([type])
    @@index([isPrivate])
    @@map("chats")
}

model ChatMember {
    id         String    @id @default(cuid())
    joinedAt   DateTime  @default(now()) @map("joined_at")
    lastReadAt DateTime? @map("last_read_at")

    role EnumMemberRole @default(MEMBER)

    chat   Chat   @relation(fields: [chatId], references: [id], onDelete: Cascade)
    chatId String @map("chat_id")
    user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
    userId String @map("user_id")

    @@unique([chatId, userId])
    @@index([userId])
    @@index([chatId])
    @@map("chat_members")
}

model ChatAdmin {
    id      String   @id @default(cuid())
    addedAt DateTime @default(now()) @map("added_at")

    chat   Chat   @relation(fields: [chatId], references: [id], onDelete: Cascade)
    chatId String @map("chat_id")
    user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
    userId String @map("user_id")

    @@unique([chatId, userId])
    @@map("chat_admins")
}

model Message {
    id             String    @id @default(cuid())
    content        String?
    pinnedByUserId String?   @map("pinned_by_user_id")
    isEdited       Boolean   @default(false) @map("is_edited")
    isSystem       Boolean   @default(false) @map("is_system")
    createdAt      DateTime  @default(now()) @map("created_at")
    updatedAt      DateTime  @updatedAt @map("updated_at")
    deletedAt      DateTime? @map("deleted_at")

    chat     Chat            @relation(fields: [chatId], references: [id], onDelete: Cascade)
    chatId   String          @map("chat_id")
    sender   User            @relation(fields: [senderId], references: [id])
    senderId String          @map("sender_id")
    media    Media[]
    statuses MessageStatus[]

    replyTo         Message?  @relation("MessageReplies", fields: [replyToId], references: [id]) // Сообщение, на которое отвечаем
    replyToId       String?   @map("reply_to_id")
    replies         Message[] @relation("MessageReplies")
    forwardedFrom   Message?  @relation("MessageForwards", fields: [forwardedFromId], references: [id]) // Сообщение, которое пересылаем
    forwardedFromId String?   @map("forwarded_from_id")
    forwards        Message[] @relation("MessageForwards")

    @@index([chatId, createdAt])
    @@index([senderId])
    @@index([replyToId])
    @@index([forwardedFromId])
    @@map("messages")
}

model MessageStatus {
    id        String            @id @default(cuid())
    status    EnumMessageStatus @default(SENT)
    updatedAt DateTime          @updatedAt @map("updated_at")

    message   Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
    messageId String  @map("message_id")
    user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
    userId    String  @map("user_id") // ID пользователя (получателя)

    @@unique([messageId, userId])
    @@index([userId, status])
    @@map("message_statuses")
}

model Media {
    id        String   @id @default(cuid())
    createdAt DateTime @default(now()) @map("created_at")

    type     EnumMediaType
    url      String
    fileName String?       @map("file_name")
    fileSize Int?          @map("file_size")
    safeName String        @map("safe_name")

    message   Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
    messageId String  @map("message_id")

    @@index([messageId])
    @@map("media")
}

model ArchivedChat {
    id         String   @id @default(cuid())
    archivedAt DateTime @default(now()) @map("archived_at")

    user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
    userId String @map("user_id")
    chat   Chat   @relation(fields: [chatId], references: [id], onDelete: Cascade)
    chatId String @map("chat_id")

    @@unique([userId, chatId])
    @@map("archived_chats")
}

model PinnedChat {
    id       String   @id @default(cuid())
    pinnedAt DateTime @default(now()) @map("pinned_at")

    user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
    userId String @map("user_id")
    chat   Chat   @relation(fields: [chatId], references: [id], onDelete: Cascade)
    chatId String @map("chat_id")

    @@unique([userId, chatId])
    @@map("pinned_chats")
}

model MutedChat {
    id         String    @id @default(cuid())
    mutedUntil DateTime? @map("muted_until")
    mutedAt    DateTime  @default(now()) @map("muted_at")

    user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
    userId String @map("user_id")
    chat   Chat   @relation(fields: [chatId], references: [id], onDelete: Cascade)
    chatId String @map("chat_id")

    @@unique([userId, chatId])
    @@map("muted_chats")
}

model InviteLink {
    id   String @id @default(cuid())
    link String @unique

    chat   Chat?  @relation(fields: [chatId], references: [id], onDelete: Cascade)
    chatId String @unique @map("chat_id")

    expiresAt DateTime
    createdAt DateTime @default(now())

    @@unique([id, chatId])
    @@map("invite_links")
}

model Token {
    id String @id @default(uuid())

    email     String
    token     String        @unique
    type      EnumTokenType
    expiresIn DateTime

    createdAt DateTime @default(now())

    @@map("tokens")
}

enum EnumTokenType {
    VERIFICATION
    PASSWORD_RESET
}

enum EnumUserRole {
    ADMIN
    USER
}

enum EnumUserStatus {
    ONLINE
    OFFLINE
}

enum EnumUserVisibility {
    VISIBLE
    INVISIBLE
}

enum EnumChatType {
    DIRECT
    GROUP
    CHANNEL
}

enum EnumMemberRole {
    OWNER
    ADMIN
    MEMBER
}

enum EnumMessageStatus {
    SENT
    DELIVERED
    READ
    FAILED
    DELETED
}

enum EnumMediaType {
    IMAGE
    VIDEO
    AUDIO
    DOCUMENT
    VOICE
    GIF
}

enum EnumFriendshipStatus {
    PENDING
    ACCEPTED
    DECLINED
    BLOCKED
}
